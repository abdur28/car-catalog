generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Car {
  id           String   @id @default(cuid())
  externalId   String   @unique @map("external_id")
  brand        String
  brandJp      String?  @map("brand_jp")
  model        String
  modelJp      String?  @map("model_jp")
  year         Int?
  mileage      Int?
  mileageUnit  String?  @default("km") @map("mileage_unit")
  price        Int?
  priceCurrency String? @default("JPY") @map("price_currency")
  engineSize   String?  @map("engine_size")
  transmission String?
  fuelType     String?  @map("fuel_type")
  color        String?
  bodyType     String?  @map("body_type")
  location     String?
  description  String?
  url          String?
  images       String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([brand])
  @@index([year])
  @@index([price])
  @@map("cars")
}
